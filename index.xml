<mxfile host="app.diagrams.net">
  <diagram name="Test Diagram">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- Process -->
        <mxCell id="process" value="Upload Documents" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="Filed" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="450" y="100" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="edge1" style="endArrow=block;" edge="1" parent="1" source="start" target="process">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="edge2" style="endArrow=block;" edge="1" parent="1" source="process" target="end">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
